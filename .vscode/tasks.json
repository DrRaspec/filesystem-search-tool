{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-g",
                "-std=c++17",
                "-o",
                "${workspaceFolder}/search.exe",
                "${workspaceFolder}/search.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build-release",
            "type": "shell",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-O2",
                "-DNDEBUG",
                "-std=c++17",
                "-o",
                "${workspaceFolder}/search.exe",
                "${workspaceFolder}/search.cpp"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}
